# Database
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/techsphere_ai

# Redis (optional — app works without it)
REDIS_URL=

# Security
SECRET_KEY=supersecretkey_change_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Cookie auth (hybrid with Bearer). Production auto: SameSite=None, Secure=True
# Local HTTP defaults applied when ENVIRONMENT!=production
# COOKIE_SECURE=false
# COOKIE_SAMESITE=lax

# CORS (comma-separated origins) — exact list, never * in production
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,https://technest-ai.vercel.app

# Admin account (seed)
ADMIN_EMAIL=admin@techsphere.com
ADMIN_PASSWORD=admin123
ADMIN_FULL_NAME=Admin Demo

# Sentry (error tracking - optional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# Cloudinary (image upload - optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (optional — bật khi đã verify domain trên Resend)
# onboarding@resend.dev CHỈ gửi được tới email đã add/verify trên Resend dashboard
# (test mode). Production: verify domain → EMAIL_FROM=TechSphere AI <noreply@yourdomain.com>
# Checklist: docs/DEPLOYMENT.md § Resend production
EMAIL_ENABLED=false
RESEND_API_KEY=
EMAIL_FROM=TechSphere AI <onboarding@resend.dev>

# Frontend URL (for email links and payment redirect)
# Local: http://localhost:5173 | Production: https://technest-ai.vercel.app
FRONTEND_URL=http://localhost:5173

# VNPay (sandbox)
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:8000/api/payments/vnpay-return

# AI / LLM Chatbot (optional — fallback rule-based nếu disabled / lỗi / hết key)
# Khi bật: chatbot tạo context sản phẩm từ DB rồi gọi LLM để trả lời tự nhiên.
# Sản phẩm + giá + tồn kho luôn lấy từ DB (không bịa).
AI_LLM_ENABLED=false
# AI_PROVIDERS: comma-list theo thứ tự ưu tiên. Mỗi provider lỗi → thử kế tiếp;
# hết → rule-based. Vd: "gemini,groq" → ưu tiên Gemini, fallback Groq.
# Để rỗng = dùng AI_PROVIDER làm singleton (backwards compat).
AI_PROVIDERS=gemini,groq
AI_PROVIDER=gemini
AI_LLM_TIMEOUT_SECONDS=10.0
# Cache TTL cho LLM response (Redis). 0 = disable cache.
# Cùng câu hỏi trong TTL window → hit cache, tiết kiệm quota.
AI_LLM_CACHE_TTL_SECONDS=3600

# Gemini (https://aistudio.google.com/apikey — free tier rộng)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Groq (https://console.groq.com/keys — free tier, OpenAI-compatible)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
